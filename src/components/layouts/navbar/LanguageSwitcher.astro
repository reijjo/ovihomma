---
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLocale = Astro.currentLocale ?? "fi";

const localeOptions = [
  { code: "fi", label: "Suomi", flag: "fi" },
  { code: "en", label: "English", flag: "en" },
  { code: "es", label: "Español", flag: "es" },
] as const;

function localizedHref(locale: string, key?: string) {
  return key ? getRelativeLocaleUrl(locale, key) : getRelativeLocaleUrl(locale);
}

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navKeys = ["", "tuotteet", "huolto", "meista", "yhteystiedot"] as const;
const routeKey =
  navKeys.find((key) => {
    const href = localizedHref(currentLocale, key).replace(/\/$/, "") || "/";
    return href === currentPath;
  }) ?? "";

const currentLocaleOption =
  localeOptions.find((option) => option.code === currentLocale) ??
  localeOptions[0];
---

<details class="locale-switcher">
  <summary class="locale-trigger" aria-label="Select language">
    <span
      class={`locale-flag locale-flag--${currentLocaleOption.flag}`}
      aria-hidden="true"></span>
    <span class="locale-trigger-label">{currentLocaleOption.label}</span>
    <!-- <span class="locale-caret" aria-hidden="true">⌄</span> -->
  </summary>

  <div class="locale-menu" role="listbox" aria-label="Language">
    {
      localeOptions.map((locale) => (
        <a
          href={localizedHref(locale.code, routeKey)}
          class={`locale-option ${locale.code === currentLocale ? "is-active" : ""}`}
          role="option"
          aria-selected={locale.code === currentLocale ? "true" : "false"}
        >
          <span
            class={`locale-flag locale-flag--${locale.flag}`}
            aria-hidden="true"
          />
          <span class="locale-option-label">{locale.label}</span>
        </a>
      ))
    }
  </div>
</details>

<style>
  .locale-switcher {
    position: relative;
    flex: none;
  }

  .locale-switcher > summary {
    list-style: none;
  }

  .locale-switcher > summary::-webkit-details-marker {
    display: none;
  }

  .locale-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(20, 20, 20, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: rgba(20, 20, 20, 0.92);
    cursor: pointer;
    user-select: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .locale-trigger:hover {
    border-color: rgba(20, 20, 20, 0.22);
    box-shadow: 0 6px 20px rgba(20, 20, 20, 0.06);
    transform: translateY(-1px);
  }

  .locale-trigger-label {
    font-size: 0.9rem;
    line-height: 1;
    white-space: nowrap;
  }

  .locale-caret {
    font-size: 0.7rem;
    line-height: 1;
    opacity: 0.7;
    transform: translateY(-3px);
  }

  .locale-menu {
    position: absolute;
    top: calc(100% + 0.55rem);
    right: 0;
    min-width: 11rem;
    padding: 0.35rem;
    border: 1px solid rgba(20, 20, 20, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 40px rgba(20, 20, 20, 0.1);
    opacity: 0;
    transform: translateY(-0.4rem) scale(0.98);
    transform-origin: top right;
    pointer-events: none;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .locale-switcher[open] .locale-menu {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .locale-option {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.8rem;
    color: rgba(20, 20, 20, 0.88);
    transition: background-color 160ms ease;
  }

  .locale-option:hover,
  .locale-option:focus-visible,
  .locale-option.is-active {
    background: rgba(20, 20, 20, 0.06);
    outline: none;
  }

  .locale-option-label {
    font-size: 0.9rem;
    line-height: 1;
    white-space: nowrap;
  }

  .locale-flag {
    position: relative;
    flex: none;
    width: 1.1rem;
    height: 0.78rem;
    border-radius: 999px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(20, 20, 20, 0.08);
  }

  .locale-flag--fi {
    background: #ffffff;
  }

  .locale-flag--fi::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        transparent 0 28%,
        #003580 28% 41%,
        transparent 41%
      ),
      linear-gradient(transparent 0 39%, #003580 39% 62%, transparent 62%);
  }

  .locale-flag--en {
    background:
      linear-gradient(
        90deg,
        transparent 0 36%,
        #ffffff 36% 43%,
        #c8102e 43% 57%,
        #ffffff 57% 64%,
        transparent 64%
      ),
      linear-gradient(
        transparent 0 36%,
        #ffffff 36% 43%,
        #c8102e 43% 57%,
        #ffffff 57% 64%,
        transparent 64%
      ),
      #012169;
  }

  .locale-flag--es {
    background: linear-gradient(
      to bottom,
      #aa151b 0 24%,
      #f1bf00 24% 76%,
      #aa151b 76%
    );
  }

  @media (max-width: 720px) {
    .locale-menu {
      right: 0;
      left: auto;
    }
  }
</style>
